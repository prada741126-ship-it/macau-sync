<!DOCTYPE html>
<html lang="zh-HK">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>房務系統 v7.0 - 酒店房型管理原型</title>
<style>
:root {
  --bg-page: #0d0d14;
  --bg-card: #161622;
  --bg-input: #1a1a2e;
  --gold: #D4AF37;
  --gold-dim: rgba(212,175,55,0.3);
  --gold-glow: rgba(212,175,55,0.12);
  --text: #e0dcd0;
  --text-dim: #8a8a90;
  --border: rgba(212,175,55,0.15);
  --danger: #e74c3c;
  --success: #2ecc71;
  --radius: 10px;
}
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; }
body {
  font-family: "Microsoft JhengHei", "PingFang TC", sans-serif;
  background: var(--bg-page);
  color: var(--text);
  display: flex;
  overflow: hidden;
}

/* === 側邊欄 === */
#sidebar {
  width: 240px; min-width: 240px;
  background: linear-gradient(180deg, #111122 0%, #0a0a14 100%);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  padding: 24px 16px;
  gap: 8px;
}
.sb-logo {
  font-size: 22px; font-weight: 900; color: var(--gold);
  letter-spacing: 6px; text-align: center;
  margin-bottom: 16px;
  text-shadow: 0 0 20px rgba(212,175,55,0.4);
}
.sb-subtitle {
  font-size: 9px; text-align: center; color: var(--text-dim);
  letter-spacing: 3px; margin-bottom: 8px;
}
.sb-nav {
  display: flex; flex-direction: column; gap: 4px;
  list-style: none;
}
.sb-nav li {
  padding: 10px 14px; border-radius: 6px; cursor: pointer;
  color: var(--text-dim); font-size: 13px; transition: all 0.2s;
  border: 1px solid transparent;
}
.sb-nav li:hover { color: var(--gold); background: rgba(212,175,55,0.05); }
.sb-nav li.active {
  color: var(--gold); background: rgba(212,175,55,0.1);
  border-color: var(--gold-dim); font-weight: 600;
}
.sb-version {
  margin-top: auto; font-size: 10px; color: var(--text-dim);
  text-align: center; padding-top: 16px;
  border-top: 1px solid var(--border);
}

/* === 主內容 === */
#main-content { flex:1; display:flex; flex-direction:column; overflow:hidden; min-width:0; }

/* Top bar */
.topbar {
  padding: 14px 28px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(22,22,34,0.6);
}
.page-title { font-size: 18px; font-weight: 700; color: var(--gold); }
.page-title span { font-size: 12px; color: var(--text-dim); font-weight: 400; margin-left: 8px; }

/* Scroll area */
#page-scroll { flex:1; overflow-y:auto; padding: 20px 28px 40px; }

/* Section titles */
.section-title {
  font-size: 15px; font-weight: 600; color: var(--gold);
  margin-bottom: 14px; padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px;
}
.section-title .toggle-btn {
  font-size: 11px; color: var(--text-dim); cursor: pointer;
  padding: 3px 10px; border: 1px solid var(--border); border-radius: 4px;
  background: transparent; transition: all 0.2s;
}
.section-title .toggle-btn:hover { color: var(--gold); border-color: var(--gold-dim); }
.section-count {
  font-size: 11px; color: var(--text-dim); font-weight: 400;
  margin-left: auto;
}

/* === 酒店管理表格 === */
.config-table-wrap {
  background: var(--bg-card); border-radius: var(--radius);
  border: 1px solid var(--border); overflow: hidden;
  margin-bottom: 24px;
  overflow-x: auto;
}
.config-table {
  width: 100%; border-collapse: collapse; font-size: 13px;
  min-width: 700px;
}
.config-table thead th {
  background: rgba(212,175,55,0.08); padding: 10px 12px;
  text-align: left; font-weight: 600; font-size: 12px;
  color: var(--gold); border-bottom: 2px solid var(--gold-dim);
  white-space: nowrap;
}
.config-table thead th.num { text-align: center; }
.config-table tbody td {
  padding: 8px 12px; border-bottom: 1px solid rgba(255,255,255,0.04);
  vertical-align: middle;
}
.config-table tbody tr:hover { background: rgba(212,175,55,0.03); }
.config-table tbody tr.row-new { background: rgba(46,204,113,0.06); }
.config-table tbody tr.row-delete {
  opacity: 0.3; text-decoration: line-through;
  transition: all 0.3s;
}

/* Inline edit inputs */
.config-table input, .config-table select {
  width: 100%; padding: 5px 8px; font-size: 13px;
  background: var(--bg-input); color: var(--text);
  border: 1px solid var(--border); border-radius: 4px;
  outline: none; font-family: inherit;
  min-width: 60px;
}
.config-table input:focus, .config-table select:focus {
  border-color: var(--gold); box-shadow: 0 0 6px var(--gold-glow);
}
.config-table input.num-input { width:70px; text-align:center; }
.config-table td.actions {
  white-space: nowrap; text-align: center; min-width: 60px;
}

/* 按鈕 */
.btn {
  padding: 7px 16px; border: 1px solid transparent; border-radius: 6px;
  font-size: 12px; cursor: pointer; font-family: inherit;
  transition: all 0.2s; white-space: nowrap;
}
.btn-gold { background: linear-gradient(180deg, #b8941f, #8b6914); color: #fff; border-color: var(--gold-dim); }
.btn-gold:hover { background: linear-gradient(180deg, #d4a830, #a07818); }
.btn-ghost { background: transparent; color: var(--text-dim); border-color: var(--border); }
.btn-ghost:hover { color: var(--gold); border-color: var(--gold-dim); }
.btn-danger { background: transparent; color: var(--danger); border-color: rgba(231,76,60,0.3); }
.btn-danger:hover { background: rgba(231,76,60,0.1); }
.btn-sm { padding: 3px 10px; font-size: 11px; }
.btn-xs { padding: 2px 8px; font-size: 10px; border-radius: 3px; }
.btn-icon { width:26px; height:26px; padding:0; display:inline-flex; align-items:center; justify-content:center; }

/* Toolbar */
.toolbar {
  display: flex; gap: 10px; align-items: center; margin-bottom: 16px;
  flex-wrap: wrap;
}
.toolbar .filter-group {
  display: flex; gap: 6px; align-items: center;
}
.toolbar select {
  padding: 6px 12px; font-size: 12px; background: var(--bg-input);
  color: var(--text); border: 1px solid var(--border); border-radius: 6px;
  font-family: inherit;
}

/* === 訂房表單區 === */
.booking-demo {
  background: var(--bg-card); border-radius: var(--radius);
  border: 1px solid var(--border); padding: 20px 24px;
  margin-bottom: 24px;
}
.form-row {
  display: flex; gap: 14px; margin-bottom: 12px;
  flex-wrap: wrap;
}
.form-group { display: flex; flex-direction: column; gap: 4px; flex:1; min-width: 130px; }
.form-group label { font-size: 11px; color: var(--text-dim); letter-spacing: 1px; }
.form-group input, .form-group select {
  padding: 8px 12px; font-size: 13px; background: var(--bg-input);
  color: var(--text); border: 1px solid var(--border); border-radius: 6px;
  outline: none; font-family: inherit;
}
.form-group input:focus, .form-group select:focus {
  border-color: var(--gold);
}
.form-group .threshold-display {
  padding: 8px 12px; font-size: 13px; color: var(--gold);
  background: rgba(212,175,55,0.06); border: 1px solid var(--gold-dim);
  border-radius: 6px; text-align: center; font-weight: 600;
}
.form-actions {
  display: flex; gap: 10px; justify-content: flex-end; margin-top: 8px;
}
.status-radio { display: flex; gap: 16px; padding: 8px 0; }
.status-radio label { cursor: pointer; display: flex; align-items: center; gap: 4px; font-size: 13px; }
.status-radio input[type="radio"] { accent-color: var(--gold); }

/* 複選框樣式 */
.config-table input[type="checkbox"] {
  width:16px; height:16px; accent-color: var(--gold); cursor:pointer;
}
.batch-bar {
  display:flex; gap:8px; align-items:center;
  background: rgba(231,76,60,0.08); border:1px solid rgba(231,76,60,0.25);
  border-radius:6px; padding:6px 12px; font-size:12px; color:#e74c3c;
  margin-bottom:10px; flex-wrap:wrap;
}
.batch-bar .batch-info { font-weight:600; }
.config-table tbody tr.selected { background: rgba(231,76,60,0.06); }

/* === 快速新增小窗 === */
.quick-add-bg {
  display: none; position: fixed; top:0; left:0; width:100%; height:100%;
  background: rgba(0,0,0,0.7); z-index: 9999;
  align-items: center; justify-content: center;
}
.quick-add-bg.show { display: flex; }
.quick-add-box {
  background: var(--bg-card); border: 1px solid var(--gold-dim);
  border-radius: 12px; padding: 24px; width: 360px; max-width: 90vw;
  box-shadow: 0 0 40px rgba(212,175,55,0.15);
}
.quick-add-box h3 { font-size: 16px; color: var(--gold); margin-bottom: 16px; text-align: center; }
.quick-add-box .form-row { gap: 10px; }
.quick-add-box .form-group { min-width: 0; }
.quick-add-box .form-group input { padding: 6px 10px; }

/* === Toast === */
.toast-container { position:fixed; top:20px; right:20px; z-index:99999; display:flex; flex-direction:column; gap:8px; }
.toast-item {
  padding: 10px 18px; border-radius: 8px; font-size: 13px;
  color: #fff; box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  animation: slideIn 0.3s ease;
}
.toast-success { background: rgba(46,204,113,0.9); }
.toast-error { background: rgba(231,76,60,0.9); }
.toast-info { background: rgba(212,175,55,0.9); color: #1a1a2e; }
@keyframes slideIn { from { opacity:0; transform:translateX(30px); } to { opacity:1; transform:translateX(0); } }

/* === 響應式 === */
@media (max-width: 900px) {
  #sidebar { display: none; }
  .topbar { padding: 10px 14px; }
  #page-scroll { padding: 14px 10px 30px; }
  .form-row { flex-direction: column; }
  .config-table { font-size: 12px; }
  .config-table input, .config-table select { font-size: 12px; }
  .toolbar { gap: 6px; }
  .quick-add-box { width: 95vw; padding: 18px 14px; }
}
@media (max-width: 480px) {
  .topbar { flex-direction: column; gap: 8px; align-items: flex-start; }
  .section-title { font-size: 13px; flex-wrap: wrap; }
  .btn { font-size: 11px; padding: 6px 10px; }
}
</style>
</head>
<body>

<!-- 側邊欄 -->
<div id="sidebar">
  <div class="sb-logo">博盈國際會</div>
  <div class="sb-subtitle">BOYING INTERNATIONAL CLUB</div>
  <ul class="sb-nav">
    <li>📊 總覽</li>
    <li>📋 全部交易</li>
    <li>🔍 查詢</li>
    <li>📈 統計</li>
    <li class="active">🏨 房務系統</li>
  </ul>
  <div class="sb-version">v7.0 原型 · 酒店管理</div>
</div>

<!-- 主內容 -->
<div id="main-content">
  <div class="topbar">
    <div class="page-title">🏨 房務系統 <span>v7.0 原型 — 酒店房型管理</span></div>
    <div style="display:flex;gap:8px;">
      <button class="btn btn-ghost" onclick="resetToPreset()">🔄 重置預設</button>
      <button class="btn btn-gold" onclick="toggleConfigTable()" id="toggle-btn">⚙ 管理設定</button>
    </div>
  </div>

  <div id="page-scroll">

    <!-- 使用說明 -->
    <div style="background:rgba(212,175,55,0.06);border:1px solid var(--border);border-radius:var(--radius);padding:14px 20px;margin-bottom:20px;font-size:12px;color:var(--text-dim);line-height:1.8;">
      <strong style="color:var(--gold);">💡 使用說明</strong><br>
      ① 下方<strong>酒店房間設定表</strong>可直接編輯，像 Excel — 點儲存格修改，Enter 或失焦自動儲存<br>
      ② 訂房表單使用<strong>三級聯動下拉</strong>：選賭場 ➜ 酒店選項自動過濾 ➜ 房型選項自動過濾<br>
      ③ 下拉選單旁的 <strong style="color:var(--gold);">＋</strong> 按鈕可<strong>快速新增</strong>酒店或房型，無需離開頁面<br>
      ④ 已修改的項目會有<span style="color:#f39c12;">★</span>標記，點「⚙ 管理設定」可開關設定表<br>
      ⑤ 「🔄 重置預設」會恢復原始澳門酒店配置（⚠️你手動新增的會保留，不重複）
    </div>

    <!-- 酒店房間設定表 -->
    <div class="config-table-wrap" id="config-table-wrap">
      <div class="section-title">
        📋 酒店房間設定
        <span class="section-count" id="config-count">共 0 項</span>
        <button class="toggle-btn" onclick="toggleConfigTable()">收起</button>
      </div>

      <!-- 篩選工具欄 -->
      <div class="toolbar" style="padding:0 16px;">
        <div class="filter-group">
          <select id="filter-casino" onchange="filterConfig()">
            <option value="">全部賭場</option>
          </select>
          <select id="filter-hotel" onchange="filterConfig()">
            <option value="">全部酒店</option>
          </select>
        </div>
        <button class="btn btn-gold btn-sm" onclick="addNewConfigRow()">＋ 新增項目</button>
        <button class="btn btn-danger btn-sm" onclick="batchDelete()" id="btn-batch-delete" style="display:none;">🗑️ 批量刪除（已選 <span id="batch-count">0</span> 項）</button>
        <span id="modified-indicator" style="font-size:11px;color:#f39c12;display:none;">★ 有未儲存的修改</span>
      </div>

      <table class="config-table" id="config-table">
        <thead>
          <tr>
            <th style="width:40px;text-align:center;"><input type="checkbox" onchange="toggleSelectAll(this)" id="select-all-cb"></th>
            <th style="width:130px">賭場</th>
            <th style="width:140px">酒店</th>
            <th style="width:120px">房型</th>
            <th class="num" style="width:90px">轉碼門檻(萬)</th>
            <th style="width:80px">操作</th>
          </tr>
        </thead>
        <tbody id="config-tbody">
          <tr><td colspan="5" style="text-align:center;color:var(--text-dim);padding:30px;">載入中...</td></tr>
        </tbody>
      </table>
    </div>

    <!-- 訂房表單 Demo -->
    <div class="booking-demo">
      <div class="section-title">📝 新增訂房（表單展示 — 三級聯動）</div>

      <div class="form-row">
        <div class="form-group" style="flex:1; min-width:140px;">
          <label>賭場</label>
          <div style="display:flex; gap:4px;">
            <select id="f-casino" onchange="onCasinoChange()" style="flex:1;">
              <option value="">請選擇賭場</option>
            </select>
          </div>
        </div>
        <div class="form-group" style="flex:1; min-width:140px;">
          <label>酒店</label>
          <div style="display:flex; gap:4px;">
            <select id="f-hotel" onchange="onHotelChange()" style="flex:1;">
              <option value="">請先選賭場</option>
            </select>
            <button class="btn btn-ghost btn-icon btn-sm" title="快速新增酒店" onclick="quickAddHotel()" style="flex-shrink:0;">＋</button>
          </div>
        </div>
        <div class="form-group" style="flex:1; min-width:140px;">
          <label>房型</label>
          <div style="display:flex; gap:4px;">
            <select id="f-room" onchange="onRoomChange()" style="flex:1;">
              <option value="">請先選酒店</option>
            </select>
            <button class="btn btn-ghost btn-icon btn-sm" title="快速新增房型" onclick="quickAddRoom()" style="flex-shrink:0;">＋</button>
          </div>
        </div>
        <div class="form-group" style="max-width:110px;">
          <label>轉碼門檻</label>
          <div class="threshold-display" id="f-threshold">-- 萬</div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group" style="flex:1;"><label>代理</label><select id="f-agent"><option>代理A</option><option>代理B</option><option>代理C</option></select></div>
        <div class="form-group" style="flex:1;"><label>客戶</label><input type="text" id="f-client" placeholder="客戶名稱"></div>
        <div class="form-group" style="flex:0.5; min-width:80px;"><label>月份</label><select id="f-month"><option>6月</option><option>7月</option><option>8月</option></select></div>
        <div class="form-group" style="flex:0.5; min-width:70px;"><label>日期</label><select id="f-day"><option>1</option><option>2</option><option>3</option></select></div>
      </div>

      <div class="form-row">
        <div class="form-group" style="flex:1;"><label>入住日期</label><select id="f-checkin-month"><option>6月</option></select><select id="f-checkin-day" style="margin-top:4px;"><option>1</option></select></div>
        <div class="form-group" style="flex:1;"><label>退房日期</label><select id="f-checkout-month"><option>6月</option></select><select id="f-checkout-day" style="margin-top:4px;"><option>2</option></select></div>
        <div class="form-group" style="flex:0.5; min-width:60px;"><label>天數</label><input type="number" id="f-nights" value="1" min="1"></div>
        <div class="form-group" style="flex:1;"><label>每晚單價(HKD)</label><input type="number" id="f-price" placeholder="0"></div>
        <div class="form-group" style="flex:1;"><label>總費用(HKD)</label><input type="number" id="f-total" placeholder="自動計算" readonly style="background:rgba(30,30,40,0.6);"></div>
      </div>

      <div class="form-row">
        <div class="form-group" style="flex:1;">
          <label>狀態</label>
          <div class="status-radio">
            <label><input type="radio" name="f-status" value="free" checked onchange="onStatusChange()"> 🆓 免費</label>
            <label><input type="radio" name="f-status" value="paid" onchange="onStatusChange()"> 💰 付費</label>
          </div>
        </div>
        <div class="form-group" style="flex:2;"><label>備註</label><input type="text" id="f-note" placeholder="備註"></div>
      </div>

      <div class="form-actions">
        <button class="btn btn-ghost">取消</button>
        <button class="btn btn-gold" onclick="demoSaveBooking()">💾 儲存訂房（Demo）</button>
      </div>
    </div>

    <!-- Demo 訂房記錄 -->
    <div class="booking-demo" id="booking-log-wrap" style="display:none;">
      <div class="section-title">📋 Demo 訂房記錄 <span class="section-count" id="booking-count"></span></div>
      <div style="font-size:12px;color:var(--text-dim);margin-bottom:8px;">（僅供原型展示，不影響正式報表。重整頁面後會清除）</div>
      <table class="config-table" style="font-size:12px;">
        <thead>
          <tr><th>日期</th><th>代理</th><th>客戶</th><th>賭場/酒店 · 房型</th><th>門檻</th><th>天數</th><th>總費</th><th>狀態</th><th>備註</th></tr>
        </thead>
        <tbody id="booking-tbody"></tbody>
      </table>
    </div>

  </div>
</div>

<!-- 快速新增小窗 -->
<div class="quick-add-bg" id="quick-add-bg">
  <div class="quick-add-box">
    <h3 id="quick-add-title">快速新增</h3>
    <div class="form-row"><div class="form-group"><label id="qa-label1"></label><input id="qa-input1"></div></div>
    <div class="form-row"><div class="form-group"><label id="qa-label2"></label><input id="qa-input2"></div></div>
    <div class="form-row" id="qa-threshold-row"><div class="form-group"><label>轉碼門檻(萬)</label><input id="qa-threshold" type="number" value="80"></div></div>
    <div class="form-actions">
      <button class="btn btn-ghost" onclick="closeQuickAdd()">取消</button>
      <button class="btn btn-gold" onclick="confirmQuickAdd()">確認新增</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast-container" id="toast-container"></div>

<script>
// ===== 預設酒店數據 =====
var PRESET_CONFIG = [
  // 新濠
  { casino:"新濠", hotel:"君悅",    room:"大床房", threshold:80 },
  { casino:"新濠", hotel:"君悅",    room:"雙床房", threshold:80 },
  { casino:"新濠", hotel:"君悅",    room:"小套房", threshold:120 },
  { casino:"新濠", hotel:"君悅",    room:"大套房", threshold:180 },
  { casino:"新濠", hotel:"頤居",    room:"大床房", threshold:70 },
  { casino:"新濠", hotel:"頤居",    room:"雙床房", threshold:70 },
  { casino:"新濠", hotel:"頤居",    room:"小套房", threshold:110 },
  { casino:"新濠", hotel:"頤居",    room:"大套房", threshold:160 },
  { casino:"新濠", hotel:"摩柏斯",  room:"標準房", threshold:100 },
  { casino:"新濠", hotel:"摩柏斯",  room:"套房",   threshold:200 },
  { casino:"新濠", hotel:"迎尚",    room:"標準房", threshold:60 },
  { casino:"新濠", hotel:"迎尚",    room:"套房",   threshold:100 },
  // 銀河
  { casino:"銀河", hotel:"銀河酒店",   room:"大床房", threshold:70 },
  { casino:"銀河", hotel:"銀河酒店",   room:"雙床房", threshold:70 },
  { casino:"銀河", hotel:"銀河酒店",   room:"套房",   threshold:130 },
